{{ 'diamond-selector.css' | asset_url | stylesheet_tag }}

{%- assign proxy_base = '/apps/' | append: block.settings.proxy_subpath -%}

<div
  class="avita-ds avita-ds--compact is-loading"
  data-avita-ds
  data-product-id="{{ product.id }}"
  data-product-gid="gid://shopify/Product/{{ product.id }}"
  data-shape="{{ block.settings.shape | default: 'emerald' | downcase }}"
  data-cart-type="{{ settings.cart_type | default: 'drawer' }}"
  data-proxy-base="{{ proxy_base }}"
  data-base-price="{{ product.price }}"
  data-base-label="{{ block.settings.base_label | default: product.title | escape }}"
  data-moneyformat="{{ shop.money_format | escape }}"
  data-featured-image="{% if product.featured_image %}{{ product.featured_image | image_url: width: 900 }}{% endif %}"
  {{ block.shopify_attributes }}
>
  <div class="avita-ds__stage">
    <div class="avita-ds__loader" data-ds-loader aria-hidden="true"><span class="avita-ds__spinner"></span></div>

    <div class="avita-ds__selector">
      <div class="avita-ds__step" data-ds-step="origin">
        <div class="avita-ds__step-label"><span class="avita-ds__name">Diamond</span>
          <span class="avita-ds__hint" data-ds-hint-origin>Choose an origin</span></div>
        <div class="avita-ds__chips" data-ds-origin></div>
      </div>

      <div class="avita-ds__step is-locked" data-ds-step="carat">
        <div class="avita-ds__step-label"><span class="avita-ds__name">Carat</span>
          <span class="avita-ds__hint">Weight</span></div>
        <select class="avita-ds__select" data-ds-carat><option value="">Select carat weight</option></select>
      </div>

      <div class="avita-ds__step is-locked" data-ds-step="colour">
        <div class="avita-ds__step-label"><span class="avita-ds__name">Colour</span>
          <span class="avita-ds__hint">D is finest</span></div>
        <div class="avita-ds__chips" data-ds-colour></div>
      </div>

      <div class="avita-ds__step is-locked" data-ds-step="clarity">
        <div class="avita-ds__step-label"><span class="avita-ds__name">Clarity</span>
          <span class="avita-ds__hint">VVS1 is finest</span></div>
        <div class="avita-ds__chips" data-ds-clarity></div>
      </div>

      <div class="avita-ds__step is-locked" data-ds-step="size">
        <div class="avita-ds__step-label"><span class="avita-ds__name">Ring size</span>
          <span class="avita-ds__hint">UK</span></div>
        <select class="avita-ds__select" data-ds-size></select>
      </div>

      <div class="avita-ds__summary">
        <div class="avita-ds__price-line"><span data-ds-base-label>{{ block.settings.base_label | default: product.title | escape }}</span><span class="avita-ds__v" data-ds-base>{{ product.price | money }}</span></div>
        <div class="avita-ds__price-line"><span>Selected diamond</span><span class="avita-ds__v" data-ds-stone><span class="avita-ds__pending">Pending selection</span></span></div>
        <div class="avita-ds__price-line avita-ds__total"><span class="avita-ds__k">Total</span><span class="avita-ds__v" data-ds-total>{{ product.price | money }}</span></div>
        <button class="avita-ds__cta" data-ds-cta disabled>{{ block.settings.cta_text | escape }}</button>
        <div class="avita-ds__msg" data-ds-msg hidden></div>
      </div>
    </div>
  </div>
</div>

<script src="{{ 'diamond-selector.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Diamond Selector",
  "target": "section",
  "settings": [
    { "type": "text", "id": "shape", "label": "Diamond shape (matches your CSV)", "default": "emerald" },
    { "type": "text", "id": "base_label", "label": "Base price row label (blank = product title)", "default": "Ring base" },
    { "type": "text", "id": "cta_text", "label": "Button text", "default": "Add to cart" },
    { "type": "text", "id": "proxy_subpath", "label": "App proxy subpath", "default": "diamond", "info": "Must match the app proxy subpath configured in the app (default: diamond)." }
  ]
}
{% endschema %}
